{
  "name": "mikedown-editor",
  "displayName": "MikeDown Editor",
  "description": "WYSIWYG Markdown editor for VS Code — Typora-style inline editing",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:mikedown.editor"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "mikedown.editor",
        "displayName": "MikeDown Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "mikedown.toggleBold",
        "title": "MikeDown: Toggle Bold"
      },
      {
        "command": "mikedown.toggleItalic",
        "title": "MikeDown: Toggle Italic"
      },
      {
        "command": "mikedown.toggleStrike",
        "title": "MikeDown: Toggle Strikethrough"
      },
      {
        "command": "mikedown.toggleCode",
        "title": "MikeDown: Toggle Inline Code"
      },
      {
        "command": "mikedown.undo",
        "title": "MikeDown: Undo"
      },
      {
        "command": "mikedown.redo",
        "title": "MikeDown: Redo"
      },
      {
        "command": "mikedown.toggleSourceMode",
        "title": "MikeDown: Toggle Source Mode"
      }
    ],
    "keybindings": [
      {
        "command": "mikedown.toggleBold",
        "key": "ctrl+b",
        "mac": "cmd+b",
        "when": "activeCustomEditorId == 'mikedown.editor'"
      },
      {
        "command": "mikedown.toggleItalic",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "activeCustomEditorId == 'mikedown.editor'"
      },
      {
        "command": "mikedown.toggleStrike",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s",
        "when": "activeCustomEditorId == 'mikedown.editor'"
      },
      {
        "command": "mikedown.toggleCode",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k",
        "when": "activeCustomEditorId == 'mikedown.editor'"
      },
      {
        "command": "mikedown.undo",
        "key": "ctrl+z",
        "mac": "cmd+z",
        "when": "activeCustomEditorId == 'mikedown.editor'"
      },
      {
        "command": "mikedown.redo",
        "key": "ctrl+shift+z",
        "mac": "cmd+shift+z",
        "when": "activeCustomEditorId == 'mikedown.editor'"
      },
      {
        "command": "mikedown.toggleSourceMode",
        "key": "ctrl+/",
        "mac": "cmd+/",
        "when": "activeCustomEditorId == 'mikedown.editor'"
      }
    ],
    "configuration": {
      "title": "MikeDown Editor",
      "properties": {
        "mikedown.defaultEditor": {
          "type": "boolean",
          "default": false,
          "description": "Whether MikeDown Editor is the default editor for Markdown files. When enabled, .md files open in WYSIWYG mode by default."
        },
        "mikedown.fontFamily": {
          "type": "string",
          "default": "",
          "markdownDescription": "Font family for the WYSIWYG editing area. Leave empty to use the system default sans-serif font. Example: `\"Georgia, serif\"` or `\"Inter, sans-serif\"`."
        },
        "mikedown.fontSize": {
          "type": "number",
          "default": 16,
          "minimum": 10,
          "maximum": 32,
          "description": "Font size (in pixels) for the WYSIWYG editing area."
        },
        "mikedown.linkClickBehavior": {
          "type": "string",
          "enum": [
            "navigateCurrentTab",
            "openNewTab",
            "showContextMenu"
          ],
          "enumDescriptions": [
            "Cmd+Click navigates to the link in the current editor tab",
            "Cmd+Click opens the link in a new editor tab",
            "Cmd+Click always shows a context menu with navigation options"
          ],
          "default": "openNewTab",
          "description": "What happens when you Cmd+Click (Mac) or Ctrl+Click (Windows/Linux) on a link in WYSIWYG mode."
        },
        "mikedown.autoReloadUnmodifiedFiles": {
          "type": "boolean",
          "default": true,
          "description": "Automatically reload unmodified files when external changes are detected, without prompting."
        },
        "mikedown.markdownNormalization": {
          "type": "string",
          "enum": [
            "preserve",
            "normalize"
          ],
          "enumDescriptions": [
            "Preserve original markdown syntax choices (default list markers, heading styles, etc.)",
            "Normalize markdown to a consistent style on save"
          ],
          "default": "preserve",
          "description": "Whether to normalize markdown syntax when saving."
        },
        "mikedown.normalizationStyle.boldMarker": {
          "type": "string",
          "enum": [
            "**",
            "__"
          ],
          "default": "**",
          "description": "Which bold marker to use when normalization is enabled."
        },
        "mikedown.normalizationStyle.italicMarker": {
          "type": "string",
          "enum": [
            "*",
            "_"
          ],
          "default": "*",
          "description": "Which italic marker to use when normalization is enabled."
        },
        "mikedown.normalizationStyle.listMarker": {
          "type": "string",
          "enum": [
            "-",
            "*",
            "+"
          ],
          "default": "-",
          "description": "Which unordered list marker to use when normalization is enabled."
        },
        "mikedown.normalizationStyle.headingStyle": {
          "type": "string",
          "enum": [
            "atx",
            "setext"
          ],
          "enumDescriptions": [
            "ATX-style headings: # Heading 1, ## Heading 2",
            "Setext-style headings: Heading 1 with === underline, Heading 2 with --- underline"
          ],
          "default": "atx",
          "description": "Which heading style to use when normalization is enabled."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src --ext ts",
    "format": "prettier --write \"src/**/*.{ts,html,css,js}\""
  },
  "devDependencies": {
    "@types/node": "^20.19.35",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "prettier": "^3.8.1",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.105.3",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.0",
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/language": "^6.10.8",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.36.4",
    "@tiptap/core": "^3.20.0",
    "@tiptap/extension-code-block-lowlight": "^3.20.0",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/extension-table": "^3.20.0",
    "@tiptap/extension-table-cell": "^3.20.0",
    "@tiptap/extension-table-header": "^3.20.0",
    "@tiptap/extension-table-row": "^3.20.0",
    "@tiptap/extension-task-item": "^3.20.0",
    "@tiptap/extension-task-list": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "lowlight": "^3.3.0",
    "tiptap-markdown": "^0.9.0"
  }
}
